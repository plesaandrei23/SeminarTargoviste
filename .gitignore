# ── Dependencies ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts

# ── Testing ──────────────────────────────────────────────────
/coverage
*.tsbuildinfo

# ── Env files & secrets (NEVER commit) ───────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
sanity.config.local.*
sanity.cli.local.*

# ── Editor & OS noise ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.sublime-*

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── Claude/MCP local state (keep .claude/, ignore local overrides) ─
.claude/settings.local.json
.claude/snapshots/

# ── Scrape cache (regeneratable from scripts/scrape/*.mjs) ───
/scripts/scrape/raw/
# Images are large (~95MB) and re-fetchable via download-images.mjs.
# They're committed to the CMS during Phase 3, not to git.
/scripts/scrape/images/
