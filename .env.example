# ── Sanity ──────────────────────────────────────────────────────
# Get these from https://sanity.io/manage after creating a project.
# All NEXT_PUBLIC_* values are safe to expose client-side.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-23

# Server-only — DO NOT prefix with NEXT_PUBLIC_.
# Used by the import script (scripts/import-to-sanity.mjs).
# Create at https://sanity.io/manage/personal/project/<id>/api/tokens
# Permissions: Editor (read + write).
SANITY_API_TOKEN=

# ── Contact form (Resend) ──────────────────────────────────────────
# Sign up at https://resend.com (free tier: 3000 emails/month, 100/day).
# API token from https://resend.com/api-keys (full-access for sending only).
RESEND_API_KEY=

# Inbox that receives form submissions. Defaults to siteConfig.contact.email.
CONTACT_TO_EMAIL=

# Display sender. While the domain isn't verified, use Resend's default
# (onboarding@resend.dev) — the form action falls back to it automatically.
# Once seminarortodoxtargoviste.ro is verified in Resend, set this to e.g.
# "Seminarul Teologic <contact@seminarortodoxtargoviste.ro>".
CONTACT_FROM_EMAIL=
